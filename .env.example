# Frontend runtime template for local development.
# Copy to .env when you want webpack builds to inject non-default runtime endpoints.

TIMD_BACKEND_BASE_URL=http://127.0.0.1:8787
TIMD_SOCKET_BASE_URL=http://127.0.0.1:8787/

# Leave Jitsi unset for normal localhost development.
# Set these only when you have a real Jitsi deployment.
# TIMD_JITSI_DOMAIN=meet.example.edu
# TIMD_JITSI_MUC=conference.meet.example.edu
# TIMD_JITSI_SERVICE_URL=https://meet.example.edu/http-bind
# TIMD_JITSI_CLIENT_NODE=https://meet.example.edu/jitsimeet