# Backend runtime template for local development.
# Copy this file to server/.env.local for the default local backend startup path.
# You can override the file path with SERVER_ENV_FILE=/absolute/or/relative/path.env.

HOST=127.0.0.1
PORT=8787
TIMD_FRONTEND_BASE_URL=http://127.0.0.1:8000/
AUTH_SESSION_COOKIE_NAME=timd_session
AUTH_SESSION_TTL_SECONDS=28800
SERVER_STATE_DB_FILE=data/state.sqlite

TIMD_DEFAULT_ORGANIZATION=ThisIsMyDepartment.AI
TIMD_DEFAULT_DEPARTMENT=Department
TIMD_DEFAULT_ROOM_ID=department-room
TIMD_DEFAULT_ROOM_DISPLAY_NAME=ThisIsMyDepartment.AI Room

# Keep this enabled only for local adapter testing.
AUTH_ALLOW_INSECURE_DEV_HANDOFF=true

# Optional local auth experiments.
# AUTH_HANDOFF_SHARED_SECRET=replace-me
# AUTH_JWT_SHARED_SECRET=replace-me
# AUTH_JWT_ISSUER=https://sso.example.edu
# AUTH_JWT_AUDIENCE=thisismydepartment-local
# AUTH_POSTMESSAGE_ALLOWED_ORIGINS=http://127.0.0.1:8000

# Avatar LLM routing.
# If TIMD_AGENT_LLM_PROVIDER is unset, the backend prefers OPENROUTER_API_KEY,
# then OPENAI_API_KEY, and falls back to mock mode when neither is configured.
# TIMD_AGENT_LLM_PROVIDER=openrouter

# OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_APP_NAME=ThisIsMyDepartment.AI Local
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1/

# Mock fallback
# MOCK_LLM_MODEL=local-context-preview