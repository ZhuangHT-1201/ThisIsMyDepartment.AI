{
    "$schema": "https://json.schemastore.org/tsconfig#",
    "compilerOptions": {
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "module": "commonjs",
        "newLine": "lf",
        "outDir": "dist",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "es2020",
        "lib": ["es2020"],
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "types": ["node"]
    },
    "include": ["src/**/*", "../shared/types/**/*"]
}